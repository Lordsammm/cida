    <strong>{{ fw.framework | upper }}</strong>
    <span class="pill {% if fw.coverage_pct >= 70 %}pill-pass{% elif fw.coverage_pct >= 40 %}pill-na{% else %}pill-fail{% endif %}">
      {{ fw.coverage_pct | round(0) | int }}% aligned
    </span>
    <span class="small">{{ fw.controls_aligned }} / {{ fw.controls_total }} controls</span>
  </div>
  {% if fw.top_gaps %}
  <div class="small"><strong>Key gaps:</strong> {{ fw.top_gaps | join(', ') }}</div>
