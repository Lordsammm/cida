  </div>
  <div class="posture-detail">Score {{ vs.score_0_100 | round(0) | int }}/100 &nbsp;·&nbsp; {{ vs.confidence.value | title if vs.confidence.value is defined else vs.confidence | string | title }} confidence</div>
</div>
