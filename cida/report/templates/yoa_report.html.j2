<h2><span class="sec-num">11</span> Cyber Incident Detection &amp; Response Readiness</h2>
{% set tier = report.tier %}
<div class="info-box">
  <strong>Overall Readiness: Tier {{ tier.tier }} — {{ tier.label }}</strong><br>
  {{ tier.description }}
</div>

{% if rs and rs.vector_scores %}
<h3>§11.1 Detection &amp; Response Capability</h3>
{% for vs in rs.vector_scores %}
